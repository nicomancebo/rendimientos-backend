# ── Servidor ────────────────────────────────────────
PORT=3001

# ── CORS: dominio(s) de tu frontend ─────────────────
# Separá múltiples dominios con coma
ALLOWED_ORIGINS=http://localhost:5500,https://tu-sitio.com

# ── Caché (segundos) ─────────────────────────────────
CACHE_BILLETERAS_TTL=300     # 5 minutos
CACHE_PLAZO_TTL=3600         # 1 hora (BCRA actualiza 1x/día)
CACHE_BADLAR_TTL=3600

# ── Rate limit ───────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000   # 1 minuto
RATE_LIMIT_MAX=60            # máx requests por ventana
